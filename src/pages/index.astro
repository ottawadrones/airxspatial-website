---
/**
 * index.astro — AirXSpatial homepage.
 *
 * The marketplace for engineering & survey. Phase goal: credibility. A
 * monumental dark hero, a gallery-light body, one mid-page dark reveal for the
 * supply side, and a dark closing CTA. See PRODUCT.md / DESIGN.md.
 */
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CtaStrip from '../components/CtaStrip.astro';

const base = import.meta.env.BASE_URL;

const disciplines = ['Surveying', 'Inspection', 'LiDAR', 'Photogrammetry'];

const steps = [
  {
    num: '01',
    title: 'Publish the scope',
    body: 'A developer, GC, or asset owner posts the site and the deliverable — boundary survey, façade inspection, a progress capture. Plainly, in your terms.',
  },
  {
    num: '02',
    title: 'We match the field',
    body: 'AirXSpatial routes the work to credentialed engineering firms and certified pilots near the site, in the right discipline — ready to bid.',
  },
  {
    num: '03',
    title: 'Receive the deliverable',
    body: 'Survey-grade data, documented to standard and delivered on a timeline you can build against. Traceable from field to file.',
  },
];

const partnerBenefits = [
  {
    title: 'Qualified demand, pre-scoped',
    body: 'Only projects that match your discipline, your equipment, and your coverage area. No tire-kickers.',
  },
  {
    title: 'No sales & marketing overhead',
    body: 'AirXSpatial is your go-to-market layer. You stay in the field; we bring the work to you.',
  },
  {
    title: 'Credentialing that compounds',
    body: 'Every delivery builds a verifiable track record — the kind that wins the next, larger project.',
  },
  {
    title: 'Rewarded for precision',
    body: 'The marketplace favours the firms and pilots who measure twice and deliver to standard.',
  },
];
---

<Layout
  title="The marketplace for engineering & survey"
  description="AirXSpatial connects developers and asset owners with the engineering firms and certified pilots who deliver precise surveying, inspection, LiDAR, and photogrammetry — wherever the work is."
>
  <PageHero
    size="hero"
    eyebrow="The marketplace for engineering & survey"
    headline="Ground truth for the world’s most ambitious sites."
    accentWord="Ground truth"
    accentColor="sky"
    subheadline="AirXSpatial connects developers and asset owners with the engineering firms and certified pilots who deliver precise surveying, inspection, LiDAR, and photogrammetry — wherever the work is."
    cta={{ label: 'See how it works', href: `${base}#how-it-works` }}
    ctaSecondary={{ label: 'For firms & pilots', href: `${base}#partners` }}
  />

  <!-- Discipline band — quiet proof, hairline-precise -->
  <Section variant="paper">
    <p class="site-eyebrow">Built for work that can’t be wrong</p>
    <div class="mt-6 grid grid-cols-2 gap-px overflow-hidden rounded-md border border-ink-200 bg-ink-200 sm:grid-cols-4">
      {disciplines.map((d) => (
        <div class="bg-white px-6 py-7">
          <p class="text-lg font-semibold tracking-tight text-ink-900">{d}</p>
          <p class="mt-1 font-mono text-xs uppercase tracking-widest text-ink-500">Survey-grade</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Platform — what we do -->
  <Section
    id="platform"
    variant="sunken"
    kicker={{ num: '01', label: 'What we do' }}
    heading="One marketplace. Every spatial deliverable."
    accentWord="Every spatial deliverable."
    accentColor="sky"
    lede="From a single boundary survey to a campus-scale digital twin, AirXSpatial fields the discipline the work demands — delivered by licensed firms and certified pilots, documented to the standards your project answers to."
  >
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <FeatureCard
        accent="sky"
        heading="Surveying & geomatics"
        body="Boundary, topographic, and as-built surveys delivered by licensed firms to the tolerance your project demands."
      />
      <FeatureCard
        accent="land"
        heading="Inspection & compliance"
        body="Structural, façade, and infrastructure inspections documented to the standards regulators and insurers expect."
      />
      <FeatureCard
        accent="sky"
        heading="LiDAR & point clouds"
        body="Aerial and terrestrial LiDAR captured by certified pilots and registered into survey-grade point clouds."
      />
      <FeatureCard
        accent="land"
        heading="Photogrammetry & 3D"
        body="High-resolution imagery turned into measurable orthomosaics, meshes, and digital twins of the real site."
      />
      <FeatureCard
        accent="sky"
        heading="Construction progress"
        body="Repeat captures that track a build against plan — evidence owners, lenders, and project controls can trust."
      />
      <FeatureCard
        accent="land"
        heading="A vetted network"
        body="Every firm and pilot is credentialed, insured, and matched to the work they do best. Precision is the price of entry."
      />
    </div>
  </Section>

  <!-- How it works -->
  <Section
    id="how-it-works"
    variant="paper"
    kicker={{ num: '02', label: 'How it works' }}
    heading="Three steps from scope to ground truth."
    accentWord="ground truth."
    accentColor="land"
    lede="AirXSpatial is the layer between the work and the people who can do it — the sales and marketing firm that makes bidding and winning effortless."
  >
    <ol class="mt-12 grid list-none gap-px overflow-hidden rounded-md border border-ink-200 bg-ink-200 p-0 sm:grid-cols-3">
      {steps.map((step) => (
        <li class="flex flex-col bg-white p-8">
          <span class="font-mono text-sm font-semibold tracking-widest text-sky-600">{step.num}</span>
          <h3 class="mt-5 text-lg font-bold tracking-tight text-ink-900">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-600">{step.body}</p>
        </li>
      ))}
    </ol>
  </Section>

  <!-- For firms & pilots — the one mid-page dark reveal -->
  <Section
    id="partners"
    variant="inverse"
    kicker={{ num: '03', label: 'For firms & pilots' }}
    heading="Win the work you’re built for."
    accentWord="built for."
    accentColor="sky"
    inner="wide"
    lede="Stop chasing leads. AirXSpatial brings qualified, in-scope projects to credentialed engineering firms and certified pilots — so your time goes to the field, not the funnel."
  >
    <div class="mt-12 grid gap-px overflow-hidden rounded-md border border-ink-800 bg-ink-800 sm:grid-cols-2">
      {partnerBenefits.map((b) => (
        <div class="bg-ink-950 p-8">
          <h3 class="text-base font-bold tracking-tight text-ink-50">{b.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-300">{b.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <CtaStrip
    heading="Build with people who measure twice."
    accentWord="measure twice."
    accentColor="sky"
    lede="Tell us about your site. We’ll route it to the firms and pilots who can deliver it to standard."
    cta={{ label: 'Get in touch', href: `${base}about` }}
    ctaSecondary={{ label: 'Learn about AirXSpatial', href: `${base}about` }}
  />
</Layout>
