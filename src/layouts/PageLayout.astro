---
/**
 * PageLayout.astro — content page wrapper.
 *
 * Renders: PageHero → slotted body content → CtaStrip.
 * Use this for inner pages (About, Blog post, etc.).
 */
import Layout from './Layout.astro';
import PageHero from '../components/PageHero.astro';
import CtaStrip from '../components/CtaStrip.astro';

interface Props {
  title: string;
  description?: string;
  headline?: string;
  accentWord?: string;
  accentColor?: 'multi' | 'sky' | 'land';
  eyebrow?: string;
  subheadline?: string;
  kicker?: string;
  bgImage?: string;
  bgAlt?: string;
  noIndex?: boolean;
  showCta?: boolean;
}

const {
  title,
  description,
  headline,
  accentWord,
  accentColor = 'multi',
  eyebrow,
  subheadline,
  kicker,
  bgImage,
  bgAlt,
  noIndex = false,
  showCta  = true,
} = Astro.props;
---

<Layout title={title} description={description} noIndex={noIndex}>
  <PageHero
    headline={headline ?? title}
    accentWord={accentWord}
    accentColor={accentColor}
    eyebrow={eyebrow}
    subheadline={subheadline}
    kicker={kicker}
    bgImage={bgImage}
    bgAlt={bgAlt}
  />

  <slot />

  {showCta && <CtaStrip />}
</Layout>
