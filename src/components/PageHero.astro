---
/**
 * PageHero — the dark, full-bleed page header used by every page.
 *
 * When `bgImage` is set, a photographic backdrop (architecture / aerial site)
 * carries the emotional weight, with a scrim guaranteeing headline contrast.
 * The sticky dark Nav always sits over a dark hero, so the chrome is consistent.
 */
interface Props {
  headline: string;
  accentWord?: string;
  accentColor?: 'multi' | 'sky' | 'land';
  eyebrow?: string;
  subheadline?: string;
  kicker?: string;
  size?: 'hero' | 'display';
  bgImage?: string;
  bgAlt?: string;
  cta?: { label: string; href: string; analyticsId?: string };
  ctaSecondary?: { label: string; href: string; analyticsId?: string };
}

const {
  headline,
  accentWord,
  accentColor = 'multi',
  eyebrow,
  subheadline,
  kicker,
  size = 'display',
  bgImage,
  bgAlt = '',
  cta,
  ctaSecondary,
} = Astro.props;

const accentClass =
  accentColor === 'multi' ? 'site-accent' : `site-accent--${accentColor}`;
const idx = accentWord ? headline.indexOf(accentWord) : -1;
const before = idx >= 0 ? headline.slice(0, idx) : headline;
const accent = idx >= 0 ? accentWord! : '';
const rawAfter  = idx >= 0 ? headline.slice(idx + (accentWord?.length ?? 0)) : '';
const trailingPunc = rawAfter.match(/^[.,!?;:]+/)?.[0] ?? '';
const after = trailingPunc ? rawAfter.slice(trailingPunc.length) : rawAfter;

const headlineClass = size === 'hero'
  ? 'site-headline site-headline--hero mt-5'
  : 'site-headline site-headline--display mt-5';

const [kickerLead, ...kickerRest] = (kicker ?? '').split('·').map((s) => s.trim());
const kickerTail = kickerRest.join(' · ');
---

<section
  class="page-hero section"
  data-variant="inverse"
  data-section="page-hero"
>
  {bgImage && (
    <div class="page-hero__media" aria-hidden={bgAlt ? undefined : 'true'}>
      <img class="page-hero__img" src={bgImage} alt={bgAlt} fetchpriority="high" decoding="async" />
      <div class="page-hero__scrim"></div>
    </div>
  )}

  <div class="site-glow" aria-hidden="true">
    <span class="site-glow__shape site-glow__shape--sky-tr"></span>
    <span class="site-glow__shape site-glow__shape--sky-bl"></span>
    {size === 'hero' && (
      <span class="site-glow__shape site-glow__shape--land-br"></span>
    )}
  </div>

  <div class="section__inner">
    {kicker && (
      <span class="site-kicker site-kicker--paper">
        <span class="site-kicker__num">{kickerLead}</span>
        {kickerTail && <span class="site-kicker__sep">·</span>}
        {kickerTail && <span>{kickerTail}</span>}
      </span>
    )}

    <div class={size === 'hero' ? 'mt-8 max-w-4xl' : 'mt-6 max-w-3xl'}>
      {eyebrow && <p class="site-eyebrow site-eyebrow--paper">{eyebrow}</p>}

      <h1 class={headlineClass}>
        {before}{accent && <span class={accentClass}>{accent}{trailingPunc}</span>}{after}
      </h1>

      {subheadline && (
        <p class="mt-7 max-w-2xl text-lg md:text-xl leading-relaxed text-ink-200">
          {subheadline}
        </p>
      )}

      {(cta || ctaSecondary) && (
        <div class="mt-10 flex flex-wrap items-center gap-4">
          {cta && (
            <a
              href={cta.href}
              data-analytics-id={cta.analyticsId ?? 'hero-cta-primary'}
              class="inline-flex items-center justify-center rounded-md bg-ink-50 px-6 py-3 text-sm font-semibold text-ink-900 transition-colors hover:bg-white"
            >{cta.label}</a>
          )}
          {ctaSecondary && (
            <a
              href={ctaSecondary.href}
              data-analytics-id={ctaSecondary.analyticsId ?? 'hero-cta-secondary'}
              class="inline-flex items-center justify-center rounded-md border border-ink-500 px-6 py-3 text-sm font-semibold text-ink-100 transition-colors hover:border-ink-300 hover:text-ink-50"
            >{ctaSecondary.label}</a>
          )}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .page-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .page-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  /* Contrast scrim: heavy at the lower-left where the headline lives, opening
     up to the right so the architecture reads. */
  .page-hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(95deg, var(--color-ink-950) 8%, oklch(0.16 0.013 250 / 0.78) 38%, oklch(0.16 0.013 250 / 0.30) 72%, oklch(0.16 0.013 250 / 0.55) 100%),
      linear-gradient(0deg, var(--color-ink-950) 2%, transparent 46%);
  }
  .page-hero[data-variant="inverse"] { background-color: var(--color-ink-950); }
</style>
