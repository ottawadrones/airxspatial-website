---
/**
 * CtaStrip — the dark, cinematic closing moment. A glass panel over a dusk
 * field, holding one decisive call to action. The page's final "ooh" before
 * the footer. Drama is rationed: this and the hero are the only dark sections.
 */
import SiteMark from './SiteMark.astro';

interface CtaButton {
  label: string;
  href: string;
  analyticsId?: string;
}

interface Props {
  heading?: string;
  accentWord?: string;
  accentColor?: 'sky' | 'land';
  lede?: string;
  cta?: CtaButton;
  ctaSecondary?: CtaButton;
}

const base = import.meta.env.BASE_URL;

const {
  heading      = 'Build with people who measure twice.',
  accentWord   = 'measure twice.',
  accentColor  = 'sky',
  lede         = 'Tell us about your site. We will route it to the right firms and pilots.',
  cta          = { label: 'Get in touch', href: `${base}about` },
  ctaSecondary,
} = Astro.props;

const idx = heading.indexOf(accentWord);
const before = idx >= 0 ? heading.slice(0, idx) : heading;
const accent = idx >= 0 ? accentWord : '';
const after  = idx >= 0 ? heading.slice(idx + accentWord.length) : '';
const accentClass = `site-accent--${accentColor}`;
---

<section data-variant="cta" class="section cta-strip relative isolate overflow-hidden" data-section="cta">
  <div class="site-glow" aria-hidden="true">
    <span class="site-glow__shape site-glow__shape--sky-tr"></span>
    <span class="site-glow__shape site-glow__shape--land-br"></span>
  </div>

  <div class="section__inner relative z-10">
    <div class="cta-strip__panel flex flex-col items-start gap-8 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-start gap-5">
        <SiteMark size={22} class="hidden opacity-70 sm:inline-flex" />
        <div>
          <h2 class="site-headline site-headline--display">
            {before}{accent && <span class={accentClass}>{accent}</span>}{after}
          </h2>
          {lede && <p class="mt-3 max-w-xl text-ink-200">{lede}</p>}
        </div>
      </div>

      <div class="flex flex-shrink-0 flex-wrap items-center gap-4">
        <a
          href={cta.href}
          data-analytics-id={cta.analyticsId ?? 'cta-strip-primary'}
          class="inline-flex items-center rounded-md bg-ink-50 px-5 py-2.5 text-sm font-semibold text-ink-900 transition-colors hover:bg-white"
        >{cta.label}</a>
        {ctaSecondary && (
          <a
            href={ctaSecondary.href}
            data-analytics-id={ctaSecondary.analyticsId ?? 'cta-strip-secondary'}
            class="text-sm font-medium text-ink-300 underline underline-offset-4 transition-colors hover:text-ink-50"
          >{ctaSecondary.label}</a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-strip {
    background-color: var(--color-ink-950);
    color: var(--color-ink-50);
    border-top: 1px solid var(--color-ink-800);
  }
  .cta-strip h2 {
    color: var(--color-ink-50);
  }
  .cta-strip__panel {
    padding: clamp(1.75rem, 3vw, 2.75rem);
    border: 1px solid var(--color-ink-800);
    border-top-color: var(--color-sky-600);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(180deg, oklch(0.22 0.018 250 / 0.55), oklch(0.18 0.014 250 / 0.55));
    backdrop-filter: blur(8px);
  }
</style>
