---
/**
 * SiteMark — the AirXSpatial logotype.
 *
 * A tight grotesque wordmark with the connecting "X" tinted sky (glass
 * reflecting sky). Sizes via --site-mark-size. Used on dark chrome (Nav,
 * Footer, CtaStrip), so the X uses sky-300 for presence on dark.
 */
interface Props {
  size?: number;
  label?: string;
  class?: string;
}

const { size = 18, label = 'AirXSpatial', class: className } = Astro.props;
---

<span
  class:list={['site-mark', className]}
  role="img"
  aria-label={label}
  style={`--site-mark-size: ${size}px`}
>AIR<span class="site-mark__x">X</span>SPATIAL</span>

<style>
  .site-mark {
    display: inline-flex;
    align-items: baseline;
    box-sizing: border-box;
    vertical-align: middle;
    flex: none;
    white-space: nowrap;

    font-size: var(--site-mark-size, 18px);
    font-family: var(--font-sans);
    font-weight: 800;
    font-style: normal;
    line-height: 1;
    letter-spacing: 0.10em;
    text-indent: 0.10em;
    text-transform: uppercase;
    font-feature-settings: "tnum" 1, "ss01" 1;
    font-variant-ligatures: none;
  }
  .site-mark__x {
    color: var(--color-sky-300);
    font-weight: 900;
    padding: 0 0.02em;
  }
</style>
