---
/**
 * FeatureCard — content-section card.
 *
 * A single thin brand top-rule, display heading, muted body. Optional icon
 * glyph. Brand color is restrained to the rule + icon tint (<=10% coverage).
 */
interface Props {
  icon?: string;
  heading: string;
  body: string;
  href?: string;
  accent?: 'sky' | 'land';
}

const { icon, heading, body, href, accent = 'sky' } = Astro.props;
const Tag = href ? 'a' : 'div';

const accentVar =
  accent === 'land' ? 'var(--color-land-500)' :
                      'var(--color-sky-500)';
---

<Tag
  href={href}
  class:list={[
    'feature-card group relative block bg-white p-7 transition-colors duration-200 border border-ink-200 border-t-2',
    href && 'hover:border-ink-300 cursor-pointer',
  ]}
  style={`--feature-card-accent: ${accentVar};`}
>
  {icon && (
    <div
      class="mb-5 inline-flex h-11 w-11 items-center justify-center rounded-md bg-ink-100 text-ink-900 text-lg"
      aria-hidden="true"
    >
      {icon}
    </div>
  )}
  <h3 class="text-base font-bold text-ink-900 tracking-tight">{heading}</h3>
  <p class="mt-2 text-sm text-ink-600 leading-relaxed">{body}</p>
  {href && (
    <p class="mt-4 text-sm font-medium text-ink-900 opacity-80 group-hover:opacity-100 transition-opacity">
      Learn more →
    </p>
  )}
</Tag>

<style>
  .feature-card {
    border-top-color: var(--feature-card-accent, var(--color-sky-500));
  }
</style>
