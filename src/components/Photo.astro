---
/**
 * Photo — a framed brand photograph with the shared cohesive grade.
 *
 * Rounded architectural frame + the cool "blue-hour" tint so every image on the
 * site reads as one art-directed set. Optional mono caption.
 */
interface Props {
  src: string;
  alt: string;
  ratio?: string;     // e.g. "4 / 5", "4 / 3"
  caption?: string;
  reveal?: boolean;
  class?: string;
}

const { src, alt, ratio = '4 / 3', caption, reveal = false, class: className } = Astro.props;
const revealAttr = reveal ? { 'data-reveal': '' } : {};
---

<figure class:list={['photo', className]} {...revealAttr}>
  <div class="photo__frame" style={`--photo-ratio: ${ratio};`}>
    <img class="photo__img media-grade" src={src} alt={alt} loading="lazy" decoding="async" />
    <span class="media-tint" aria-hidden="true"></span>
  </div>
  {caption && (
    <figcaption class="photo__cap">{caption}</figcaption>
  )}
</figure>

<style>
  .photo__frame {
    position: relative;
    overflow: hidden;
    aspect-ratio: var(--photo-ratio, 4 / 3);
    border-radius: 2rem;
    border: 1px solid var(--border-default);
    background: var(--color-ink-200);
  }
  .photo__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .photo__cap {
    margin-top: 0.85rem;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
</style>
