---
/**
 * Footer — closes every page.
 * Edit the nav columns to match your site structure.
 */
import SiteMark from './SiteMark.astro';
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="relative isolate overflow-hidden bg-ink-950 text-ink-50" data-section="footer">
  <div class="site-glow" aria-hidden="true">
    <span class="site-glow__shape site-glow__shape--sky-tr"></span>
    <span class="site-glow__shape site-glow__shape--sky-bl"></span>
  </div>

  <div class="relative z-10 mx-auto max-w-5xl px-6 py-14">
    <hr class="site-rule mb-10" />

    <div class="flex flex-col md:flex-row items-start justify-between gap-10">
      <div class="flex items-start gap-5">
        <SiteMark size={28} />
        <div>
          <p class="text-sm font-mono tracking-wide opacity-70">airxspatial.com</p>
          <p class="mt-2 text-sm text-ink-300 max-w-xs leading-relaxed">
            The marketplace for engineering &amp; survey — connecting firms and
            certified pilots with the surveying, inspection, LiDAR, and
            photogrammetry work the world’s sites depend on.
          </p>
        </div>
      </div>

      <nav class="grid grid-cols-2 gap-10">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-ink-300">Platform</p>
          <ul class="mt-3 space-y-2">
            <li><a href={`${base}#platform`}     class="text-sm text-ink-200 opacity-80 hover:opacity-100 transition-opacity">What we do</a></li>
            <li><a href={`${base}#how-it-works`} class="text-sm text-ink-200 opacity-80 hover:opacity-100 transition-opacity">How it works</a></li>
            <li><a href={`${base}#partners`}     class="text-sm text-ink-200 opacity-80 hover:opacity-100 transition-opacity">Firms &amp; pilots</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-ink-300">Company</p>
          <ul class="mt-3 space-y-2">
            <li><a href={`${base}about`} class="text-sm text-ink-200 opacity-80 hover:opacity-100 transition-opacity">About</a></li>
            <li><a href={`${base}about`} class="text-sm text-ink-200 opacity-80 hover:opacity-100 transition-opacity">Get in touch</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <p class="mt-10 text-xs text-ink-500">
      &copy; {year} AirXSpatial. All rights reserved.
    </p>
  </div>
</footer>
